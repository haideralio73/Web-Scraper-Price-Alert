# Gmail credentials for sending price alerts
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password-here

# Recipient email for alerts (defaults to GMAIL_USER if not set)
ALERT_RECIPIENT=your.email@gmail.com

# Scraper settings
REQUEST_TIMEOUT=30          # seconds before HTTP request times out
SCRAPE_INTERVAL_HOURS=6     # hours between price checks
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
